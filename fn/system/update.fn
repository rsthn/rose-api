
(include "./auth")

(import "lib/deploy")

(set file "conf/scripts/pull")
(when-not (path:exists (file))
    (throw "Update script not found: conf/scripts/pull"))

(gateway:header "content-type: text/html")
(gateway:persistent)

(echo "<pre>")
(echo "<b>🥗 Running update script...</b>\n")
(execute (file))
(echo "</pre>")
