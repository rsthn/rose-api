
(include "./auth")

(import "lib/directives")

{
    enabled (eq? (config.periodic.enabled) "true")
    interval (int (config.periodic.interval))
    folder_exists (path:exists "conf/periodic")
    last_run (dve:get-str "periodic_last")
    total_runs (dve:get-int "periodic_count")
    running (dve:get-int "periodic_last")
    tasks (dve:get-all "periodic_tasks")
}
